# Auto-normalize line endings: always use LF in repo regardless of OS
# This prevents "LF will be replaced by CRLF" warnings on Windows

* text=auto

# Explicitly enforce LF for text files
*.py text eol=lf
*.md text eol=lf
*.json text eol=lf
*.txt text eol=lf
*.sh text eol=lf
*.toml text eol=lf

# Binary files - do not convert
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
